{
  "version": "1.1.0",
  "description": "UI component contracts for the redesigned /apply consent-based loan wizard. Designed for Calm Credibility design system and Sahamati consent flows.",
  "designSystem": {
    "projectId": "7528632692757947510",
    "screenIds": [
      "dc5a8e715f034331a6717589c059bb8c",
      "415e76b5ed91487cb739763ee27c5330",
      "55fd61dda87743748a1d268a48aa20fc"
    ],
    "tokens": {
      "colors": {
        "primary": "#ea580c",
        "surface": "#fafaf8",
        "surface-container-lowest": "#ffffff",
        "on-surface": "#0f172a",
        "on-surface-variant": "#475569",
        "muted-border": "#e2e8f0"
      },
      "typography": {
        "display": "Instrument Serif",
        "sans": "Inter"
      },
      "shape": {
        "card": "rounded-xl",
        "button": "rounded-md"
      },
      "surface": {
        "card": "bg-white border border-nt-slate-200 shadow-sm"
      }
    }
  },
  "sharedTypes": {
    "SupportedLocale": {
      "type": "enum",
      "values": ["en", "hi", "bn", "te", "mr", "ta", "kn", "ml"]
    },
    "ApplicationStep": {
      "type": "enum",
      "values": [
        "basic_details",
        "ekyc_consent",
        "ekyc_verification",
        "pan_consent",
        "pan_verification",
        "gstin_consent",
        "gstin_verification",
        "gstin_returns",
        "bank_statement_consent",
        "bank_statement_analysis",
        "itr_upload",
        "tds_upload",
        "review_submit",
        "submission_result"
      ]
    },
    "ApplicationStatus": {
      "type": "enum",
      "values": ["draft", "submitted", "declined", "expired"]
    },
    "LoanPurpose": {
      "type": "enum",
      "values": [
        "working_capital",
        "machinery",
        "inventory",
        "business_expansion",
        "debt_refinancing",
        "other"
      ]
    },
    "DocumentType": {
      "type": "enum",
      "values": ["itr", "tds_certificate"]
    },
    "LinkStatus": {
      "type": "enum",
      "values": ["linked", "not_linked", "unknown"]
    },
    "VerificationMode": {
      "type": "enum",
      "values": ["ekyc", "pan", "gstin", "gstin_returns", "bank_statement"]
    },
    "ConsentReceipt": {
      "type": "object",
      "required": ["accepted", "statement_snapshot", "version", "locale"],
      "properties": {
        "accepted": "boolean",
        "statement_snapshot": "string (max 2000 chars)",
        "version": "string",
        "locale": "SupportedLocale",
        "data_points": "string[]",
        "purpose": "string",
        "accessors": "string[]"
      }
    },
    "FinalConsents": {
      "type": "object",
      "required": ["terms", "privacy", "credit_bureau"],
      "properties": {
        "terms": "boolean",
        "privacy": "boolean",
        "credit_bureau": "boolean",
        "marketing": "boolean (optional)"
      }
    },
    "SubmissionResult": {
      "type": "object",
      "required": ["application_id", "outcome", "status"],
      "properties": {
        "application_id": "string (uuid)",
        "outcome": "enum: submitted_success | submission_failed",
        "reference_number": "string | null",
        "next_step": "string | null",
        "support_reference": "string | null",
        "support_path": "enum: email | phone | chat_stub | null",
        "status": "ApplicationStatus"
      }
    },
    "Document": {
      "type": "object",
      "required": ["document_id", "document_type", "file_name", "status", "uploaded_at"],
      "properties": {
        "document_id": "string (uuid)",
        "document_type": "DocumentType",
        "file_name": "string",
        "mime_type": "string",
        "file_size_bytes": "number",
        "status": "enum: pending | uploaded | scanned | failed",
        "uploaded_at": "string (date-time)"
      }
    },
    "ApiError": {
      "type": "object",
      "properties": {
        "error": "string",
        "detail": "string | null",
        "message_i18n_key": "string | null",
        "field_errors": "Array<{ field: string; message: string }> | null",
        "retry_after_seconds": "number | null",
        "missing_consents": "string[] | null"
      }
    }
  },
  "components": {
    "ApplyWizard": {
      "location": "src/components/apply/ApplyWizard.tsx",
      "description": "State wrapper and responsive layout grid for the entire consent-based loan application flow.",
      "props": {
        "applicationId": {
          "type": "string | undefined",
          "required": false,
          "description": "Existing application UUID when resuming a draft."
        },
        "initialStep": {
          "type": "ApplicationStep",
          "required": false,
          "default": "basic_details",
          "description": "Step to render on first mount; server state will override once loaded."
        },
        "locale": {
          "type": "SupportedLocale",
          "required": true,
          "description": "BCP-47 locale for all borrower-facing copy."
        },
        "messages": {
          "type": "ApplyMessages",
          "required": true,
          "description": "Localized copy for labels, helper text, errors, and step titles."
        },
        "onComplete": {
          "type": "(result: SubmissionResult) => void",
          "required": true,
          "description": "Called once final submission reaches submission_result."
        }
      },
      "slots": ["header", "footer"],
      "variants": ["default"],
      "styling": {
        "layout": "centered single-column layout with max-w-2xl",
        "surface": "bg-white border border-nt-slate-200 rounded-2xl p-8 md:p-12 shadow-sm",
        "stepper": "horizontal Stepper above card on desktop"
      }
    },
    "ConsentModal": {
      "location": "src/components/apply/ConsentModal.tsx",
      "description": "Sahamati-aligned explicit consent modal with purpose, data points, accessors, and versioned statement snapshot.",
      "props": {
        "open": {
          "type": "boolean",
          "required": true,
          "description": "Dialog open state controlled by ApplyWizard."
        },
        "stepId": {
          "type": "ApplicationStep",
          "required": true,
          "description": "Consent step from the API contract that triggered the modal."
        },
        "title": {
          "type": "string",
          "required": true,
          "description": "Short step title, e.g. 'Aadhaar eKYC consent'."
        },
        "purpose": {
          "type": "string",
          "required": true,
          "description": "Human-readable purpose of collection shown prominently."
        },
        "dataPoints": {
          "type": "string[]",
          "required": true,
          "description": "List of data items being requested."
        },
        "accessors": {
          "type": "string[]",
          "required": true,
          "description": "Human-readable parties who will access the data."
        },
        "statementSnapshot": {
          "type": "string",
          "required": true,
          "description": "Exact localized consent text to store for audit."
        },
        "version": {
          "type": "string",
          "required": true,
          "description": "Stable consent statement version."
        },
        "locale": {
          "type": "SupportedLocale",
          "required": true
        },
        "onAccept": {
          "type": "(receipt: ConsentReceipt) => void",
          "required": true,
          "description": "Fired only after explicit checkbox and button affirmative."
        },
        "onCancel": {
          "type": "() => void",
          "required": true,
          "description": "Fired when the user closes or declines the modal."
        }
      },
      "slots": ["disclosure"],
      "variants": ["default", "compact"],
      "styling": {
        "overlay": "backdrop-blur-sm bg-nt-slate-900/20",
        "surface": "bg-white rounded-2xl border border-nt-slate-200 shadow-xl max-w-lg w-full p-6 md:p-8",
        "scroll": "max-h-[70vh] overflow-y-auto pr-2",
        "checkbox": "border-nt-slate-300 text-nt-orange-600"
      }
    },
    "ConsentOverlay": {
      "location": "src/components/apply/ConsentOverlay.tsx",
      "description": "Inline consent panel used inside step cards when a modal is too heavy; same Sahamati schema as ConsentModal.",
      "props": {
        "stepId": {
          "type": "ApplicationStep",
          "required": true
        },
        "title": {
          "type": "string",
          "required": true
        },
        "purpose": {
          "type": "string",
          "required": true
        },
        "dataPoints": {
          "type": "string[]",
          "required": true
        },
        "accessors": {
          "type": "string[]",
          "required": true
        },
        "statementSnapshot": {
          "type": "string",
          "required": true
        },
        "version": {
          "type": "string",
          "required": true
        },
        "locale": {
          "type": "SupportedLocale",
          "required": true
        },
        "accepted": {
          "type": "boolean",
          "required": true
        },
        "onAccept": {
          "type": "(receipt: ConsentReceipt) => void",
          "required": true
        }
      },
      "slots": ["disclosure"],
      "variants": ["default", "compact"],
      "styling": {
        "surface": "bg-nt-cream rounded-xl border border-nt-slate-200 p-5",
        "accentBar": "border-l-4 border-nt-orange-600 pl-4"
      }
    },
    "PerfiosVerificationStep": {
      "location": "src/components/apply/PerfiosVerificationStep.tsx",
      "description": "Dynamic verification step that renders Aadhaar eKYC, PAN status, GST returns, or Net Banking statement analysis loaders depending on mode.",
      "props": {
        "applicationId": {
          "type": "string",
          "required": true
        },
        "mode": {
          "type": "VerificationMode",
          "required": true,
          "description": "Which Perfios/API-backed verification to surface."
        },
        "locale": {
          "type": "SupportedLocale",
          "required": true
        },
        "bankMethod": {
          "type": "'netbanking' | 'upload' | undefined",
          "required": false,
          "description": "Required when mode is bank_statement."
        },
        "months": {
          "type": "number",
          "required": false,
          "default": 6,
          "description": "Number of bank statement months; ignored for other modes."
        },
        "consent": {
          "type": "ConsentReceipt",
          "required": true,
          "description": "Pre-captured Sahamati consent receipt for the step."
        },
        "messages": {
          "type": "PerfiosStepMessages",
          "required": true,
          "description": "Localized labels, placeholders, and status messages for each sub-mode."
        },
        "onComplete": {
          "type": "(result: PerfiosStepResult) => void",
          "required": true
        },
        "onError": {
          "type": "(error: ApiError) => void",
          "required": true
        }
      },
      "slots": ["fallback"],
      "variants": ["default"],
      "subModes": {
        "ekyc": {
          "inputs": ["aadhaar_number"],
          "status": "OTP send -> OTP input -> masked_name",
          "api": ["/apply/ekyc/send-otp", "/apply/ekyc/verify"]
        },
        "pan": {
          "inputs": ["pan_number"],
          "status": "Verifying link_status, pan_masked, name_match",
          "api": ["/apply/pan/verify"]
        },
        "gstin": {
          "inputs": ["gstin"],
          "status": "Validating legal_name",
          "api": ["/apply/gstin/verify"]
        },
        "gstin_returns": {
          "inputs": ["gstin"],
          "status": "Fetching return_history table",
          "api": ["/apply/gstin/fetch-returns"]
        },
        "bank_statement": {
          "inputs": ["bank_name?", "months"],
          "status": "Perfios widget redirect or upload fallback",
          "api": ["/apply/bank-statement/analyze"]
        }
      },
      "styling": {
        "surface": "bg-white rounded-xl border border-nt-slate-200 p-6",
        "loader": "nt-orange-600 spinner with calm status text",
        "result": "rounded-lg bg-nt-cream p-4 text-sm"
      }
    },
    "DocumentUploadZone": {
      "location": "src/components/apply/DocumentUploadZone.tsx",
      "description": "File-drop zone for ITR and Form 26AS/TDS certificate uploads with validation, scanning status, and accessible feedback.",
      "props": {
        "applicationId": {
          "type": "string",
          "required": true
        },
        "documentType": {
          "type": "DocumentType",
          "required": true
        },
        "locale": {
          "type": "SupportedLocale",
          "required": true
        },
        "acceptedMimeTypes": {
          "type": "string",
          "required": false,
          "default": "application/pdf",
          "description": "Comma-separated accept attribute for file input."
        },
        "maxSizeBytes": {
          "type": "number",
          "required": false,
          "default": 5242880,
          "description": "Max file size enforced before upload (5 MB default)."
        },
        "onUpload": {
          "type": "(document: Document) => void",
          "required": true
        },
        "onError": {
          "type": "(error: ApiError) => void",
          "required": true
        }
      },
      "slots": ["label", "hint"],
      "variants": ["default", "compact"],
      "styling": {
        "dropzone": "w-full rounded-xl border-2 border-dashed border-nt-slate-300 bg-nt-cream p-8 text-center hover:border-nt-orange-600 focus:border-nt-orange-600 transition-colors",
        "active": "border-nt-orange-600 bg-nt-orange-50",
        "error": "border-nt-red-500 bg-nt-red-50",
        "fileChip": "inline-flex items-center gap-2 rounded-md border border-nt-slate-200 bg-white px-3 py-2 text-sm"
      }
    },
    "Stepper": {
      "location": "src/components/apply/Stepper.tsx",
      "description": "Horizontal or vertical progress indicator for the apply wizard.",
      "props": {
        "steps": {
          "type": "StepConfig[]",
          "required": true
        },
        "currentStepId": {
          "type": "ApplicationStep",
          "required": true
        },
        "completedSteps": {
          "type": "ApplicationStep[]",
          "required": false,
          "default": []
        },
        "orientation": {
          "type": "'horizontal' | 'vertical'",
          "required": false,
          "default": "horizontal"
        }
      },
      "slots": [],
      "variants": ["default", "minimal"]
    },
    "NavigationFooter": {
      "location": "src/components/apply/NavigationFooter.tsx",
      "description": "Back/continue footer used inside each step card.",
      "props": {
        "onBack": {
          "type": "() => void",
          "required": false
        },
        "onContinue": {
          "type": "() => void",
          "required": true
        },
        "continueLabel": {
          "type": "string",
          "required": false,
          "default": "Continue"
        },
        "continueDisabled": {
          "type": "boolean",
          "required": false,
          "default": false
        },
        "isLoading": {
          "type": "boolean",
          "required": false,
          "default": false
        }
      },
      "slots": ["secondaryAction"],
      "variants": ["default"]
    },
    "ReviewSubmitStep": {
      "location": "src/components/apply/ReviewSubmitStep.tsx",
      "description": "Final review summary and explicit final consent capture before submission.",
      "props": {
        "applicationId": {
          "type": "string",
          "required": true
        },
        "summary": {
          "type": "SummaryGroup[]",
          "required": true
        },
        "finalConsents": {
          "type": "FinalConsents",
          "required": true
        },
        "onFinalConsentsChange": {
          "type": "(consents: FinalConsents) => void",
          "required": true
        },
        "onSubmit": {
          "type": "(result: SubmissionResult) => void",
          "required": true
        },
        "onEdit": {
          "type": "(stepId: ApplicationStep) => void",
          "required": false
        },
        "locale": {
          "type": "SupportedLocale",
          "required": true
        }
      },
      "slots": [],
      "variants": ["default"]
    }
  },
  "messageShapes": {
    "ApplyMessages": {
      "eyebrow?": "string",
      "heading?": "string",
      "description?": "string",
      "submit?": "string",
      "submitting?": "string",
      "successHeading?": "string",
      "successBody?": "string",
      "successCta?": "string",
      "errorHeading?": "string",
      "errorBody?": "string",
      "fieldRequired?": "string",
      "fullNameLabel?": "string",
      "emailLabel?": "string",
      "mobileLabel?": "string",
      "mobilePlaceholder?": "string",
      "amountLabel?": "string",
      "consentDataPrefix?": "string",
      "consentAnd?": "string",
      "consentPolicy?": "string",
      "privacyPolicy?": "string",
      "consentLender?": "string",
      "validation?": {
        "mobileInvalid?": "string",
        "emailInvalid?": "string",
        "nameInvalid?": "string",
        "consentRequired?": "string",
        "amountInvalid?": "string",
        "fileTooLarge?": "string",
        "unsupportedMedia?": "string"
      },
      "wizard?": {
        "stepIndicator?": "string[]",
        "back?": "string",
        "next?": "string",
        "saveAndContinue?": "string",
        "businessNameLabel?": "string",
        "businessNamePlaceholder?": "string",
        "entityTypeLabel?": "string",
        "entityTypes?": "Record<string, string>",
        "annualTurnoverLabel?": "string",
        "annualTurnoverPlaceholder?": "string",
        "turnoverRanges?": "Record<string, string>",
        "securityNote?": "string"
      }
    },
    "PerfiosStepMessages": {
      "ekycTitle?": "string",
      "ekycBody?": "string",
      "aadhaarLabel?": "string",
      "aadhaarPlaceholder?": "string",
      "otpLabel?": "string",
      "otpPlaceholder?": "string",
      "resendOtpLabel?": "string",
      "panTitle?": "string",
      "panBody?": "string",
      "panLabel?": "string",
      "panPlaceholder?": "string",
      "gstinTitle?": "string",
      "gstinBody?": "string",
      "gstinLabel?": "string",
      "gstinPlaceholder?": "string",
      "bankStatementTitle?": "string",
      "bankStatementBody?": "string",
      "bankNameLabel?": "string",
      "monthsLabel?": "string",
      "netbankingLabel?": "string",
      "uploadLabel?": "string",
      "genericError?": "string",
      "retryLabel?": "string"
    }
  }
}
