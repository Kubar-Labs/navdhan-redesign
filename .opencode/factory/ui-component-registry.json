{
  "version": "1.0.0",
  "project": "navdhan-redesign-2026",
  "lastUpdated": "2026-06-22",
  "contractRefs": {
    "apiContract": ".opencode/factory/api-contract.yaml",
    "dbSchema": ".opencode/factory/db-schema.yaml",
    "designBrief": "DESIGN.md"
  },
  "designTokens": {
    "fonts": {
      "ui": {
        "variable": "--font-inter",
        "source": "next/font/google Inter",
        "subsets": ["latin", "latin-ext"],
        "weights": [400, 500, 600, 700],
        "display": "swap",
        "fallback": ["Noto Sans Devanagari", "system-ui", "sans-serif"],
        "usage": ["body", "ui", "buttons", "forms"]
      },
      "display": {
        "variable": "--font-instrument-serif",
        "source": "custom Google Font import or next/local",
        "weights": [400],
        "style": "italic",
        "display": "swap",
        "fallback": ["Georgia", "serif"],
        "usage": ["hero display emphasis only"]
      }
    },
    "colors": {
      "accent": "#EA580C",
      "surfaceCream": "#FAFAF8",
      "background": "#FFFFFF",
      "textPrimary": "#0F172A",
      "textSecondary": "#475569",
      "muted": "#E2E8F0"
    },
    "radii": {
      "md": "6px",
      "xl": "12px",
      "2xl": "16px"
    },
    "spacing": {
      "baseGrid": "4px",
      "sectionPadding": "py-16 md:py-24",
      "containerMax": "max-w-7xl"
    }
  },
  "components": [
    {
      "name": "RootLayout",
      "file": "app/[locale]/layout.tsx",
      "type": "server",
      "contractRef": "#/schemas/FontContract",
      "props": [
        { "name": "children", "type": "React.ReactNode", "required": true },
        { "name": "params", "type": "{ locale: Locale }", "required": true }
      ],
      "rules": [
        "Inject --font-inter and --font-instrument-serif CSS variables via Next.js font setup.",
        "Render <html lang={locale}> with matching locale attribute.",
        "Only Inter and Instrument Serif are permitted on public marketing surfaces.",
        "font-display: swap is required for both font families."
      ]
    },
    {
      "name": "HomePage",
      "file": "app/[locale]/(marketing)/page.tsx",
      "type": "server",
      "contractRef": "#/interfaces/HomePageMapping",
      "dataSource": {
        "translatorNamespace": "home",
        "siteDataOnly": ["associationBadges", "techPartners", "recognitionItems", "emiDefaults"],
        "messageArrays": [
          "home.hero.stats",
          "home.loanProducts.products",
          "home.whyNavDhan.reasons",
          "home.whyNavDhan.trustBadges"
        ]
      },
      "sections": [
        { "order": 1, "component": "AnnouncementBar", "keys": ["global.announcement"] },
        { "order": 2, "component": "Hero", "keys": ["home.hero"] },
        {
          "order": 3,
          "component": "AssociationBadges",
          "keys": ["home.associationBadges", "global.alt"]
        },
        {
          "order": 4,
          "component": "EcosystemTicker",
          "keys": ["home.ecosystemTicker", "global.alt"]
        },
        { "order": 5, "component": "LoanProducts", "keys": ["home.loanProducts"] },
        { "order": 6, "component": "WhyNavDhan", "keys": ["home.whyNavDhan"] },
        { "order": 7, "component": "RecognitionCarousel", "keys": ["home.recognition"] },
        { "order": 8, "component": "CustomerStories", "keys": ["home.customerStories"] },
        { "order": 9, "component": "EmiCalculator", "keys": ["home.emiCalculator"] },
        { "order": 10, "component": "FinalCta", "keys": ["home.finalCta"] },
        { "order": 11, "component": "Footer", "keys": ["global.footer", "global.contact"] }
      ]
    },
    {
      "name": "LoanProducts",
      "file": "src/components/sections/LoanProducts.tsx",
      "type": "server",
      "props": [
        { "name": "t", "type": "Translator (home.loanProducts namespace)", "required": true },
        { "name": "products", "type": "ProductListItem[]", "required": true }
      ],
      "contractRef": "#/schemas/ProductListItem",
      "dataShape": {
        "eyebrow": "home.loanProducts.eyebrow",
        "heading": "home.loanProducts.heading",
        "body": "home.loanProducts.body",
        "cta": "home.loanProducts.cta",
        "productCta": "home.loanProducts.productCta",
        "products": "home.loanProducts.products"
      },
      "itemFields": {
        "id": "unique stable id",
        "titleKey": "localized title text (not a dotted key)",
        "descriptionKey": "localized body text (not a dotted key)",
        "iconName": "lucide-react icon export name",
        "ctaKey": "localized CTA text (not a dotted key)"
      },
      "notes": [
        "Items must be rendered from message array, never imported from siteData.ts.",
        "Use lucide-react dynamic icon lookup by name."
      ]
    },
    {
      "name": "WhyNavDhan",
      "file": "src/components/sections/WhyNavDhan.tsx",
      "type": "server",
      "props": [
        { "name": "t", "type": "Translator (home.whyNavDhan namespace)", "required": true },
        { "name": "reasons", "type": "ReasonListItem[]", "required": true },
        { "name": "trustBadges", "type": "string[]", "required": true }
      ],
      "contractRef": "#/schemas/ReasonListItem",
      "dataShape": {
        "eyebrow": "home.whyNavDhan.eyebrow",
        "heading": "home.whyNavDhan.heading",
        "body": "home.whyNavDhan.body",
        "cta": "home.whyNavDhan.cta",
        "reasons": "home.whyNavDhan.reasons",
        "trustBadges": "home.whyNavDhan.trustBadges"
      },
      "itemFields": {
        "id": "unique stable id",
        "titleKey": "localized title text",
        "bodyKey": "localized body text"
      },
      "notes": [
        "Trust badges array must be rendered as a single string joined with ' · ' by t().",
        "No lender-first language in reason copy."
      ]
    },
    {
      "name": "RecognitionCarousel",
      "file": "src/components/sections/RecognitionCarousel.tsx",
      "type": "server",
      "props": [
        { "name": "t", "type": "Translator (home.recognition namespace)", "required": true },
        { "name": "items", "type": "RecognitionItem[]", "required": true }
      ],
      "contractRef": "#/schemas/RecognitionItem",
      "dataShape": {
        "eyebrow": "home.recognition.eyebrow",
        "heading": "home.recognition.heading"
      },
      "itemFields": {
        "id": "stable id",
        "titleKey": "localized title text",
        "descriptionKey": "localized description text",
        "writeUp": "long-form modal content (static English for MVP)",
        "imageAsset": "primary event photo path",
        "galleryAssets": "additional event photo paths",
        "date": "year or ISO date"
      }
    },
    {
      "name": "CustomerStories",
      "file": "src/components/sections/CustomerStories.tsx",
      "type": "server",
      "props": [
        { "name": "t", "type": "Translator (home.customerStories namespace)", "required": true },
        { "name": "stories", "type": "StoryCard[]", "required": false }
      ],
      "contractRef": "#/schemas/StoryCard",
      "dataShape": {
        "eyebrow": "home.customerStories.eyebrow",
        "heading": "home.customerStories.heading",
        "cta": "home.customerStories.cta"
      },
      "itemFields": {
        "id": "stable id",
        "name": "customer name (static)",
        "roleKey": "localized role text",
        "questionKey": "localized question/quote text",
        "outcomeKey": "localized outcome text",
        "imageAsset": "real opt-in customer photo path"
      },
      "notes": [
        "If no verified opt-in stories exist, the component should gracefully omit fabricated content per DESIGN.md."
      ]
    },
    {
      "name": "EmiCalculator",
      "file": "src/components/sections/EmiCalculator.tsx",
      "type": "client",
      "props": [
        { "name": "t", "type": "Translator (home.emiCalculator namespace)", "required": true },
        { "name": "defaults", "type": "EmiDefaults", "required": true }
      ],
      "contractRef": "#/schemas/EmiDefaults",
      "dataShape": {
        "eyebrow": "home.emiCalculator.eyebrow",
        "heading": "home.emiCalculator.heading",
        "intro": "home.emiCalculator.intro",
        "amountLabel": "home.emiCalculator.amount",
        "rateLabel": "home.emiCalculator.rate",
        "tenureLabel": "home.emiCalculator.tenure",
        "monthlyLabel": "home.emiCalculator.monthly",
        "principalLabel": "home.emiCalculator.principal",
        "totalInterestLabel": "home.emiCalculator.totalInterest",
        "totalPayableLabel": "home.emiCalculator.totalPayable",
        "cta": "home.emiCalculator.cta"
      },
      "notes": [
        "Sliders update a live breakdown. Numeric defaults come from siteData.ts, labels from translator."
      ]
    },
    {
      "name": "Footer",
      "file": "src/components/shells/Footer.tsx",
      "type": "server",
      "props": [
        { "name": "locale", "type": "Locale", "required": true },
        { "name": "t", "type": "Translator (global namespace)", "required": true }
      ],
      "contractRef": "#/schemas/Messages/global/footer",
      "dataShape": {
        "tagline": "global.footer.tagline",
        "company": "global.footer.company",
        "address": "global.footer.address",
        "copyright": "global.footer.copyright",
        "contactHeading": "global.footer.contactHeading",
        "companyHeading": "global.footer.companyHeading",
        "legalHeading": "global.footer.legalHeading",
        "contactLinks": "global.footer.contactLinks",
        "companyLinks": "global.footer.companyLinks",
        "legalLinks": "global.footer.legalLinks",
        "badges": "global.footer.badges"
      },
      "rules": [
        "Render badges as a single string joined with ' · ' by t().",
        "Use labelKey from link objects as display text (already localized).",
        "Legal links must be driven by legalSlugs from src/lib/legal/loader.ts with localized labels.",
        "Registered Karnataka address and legal entity must be present."
      ]
    },
    {
      "name": "ApplyForm",
      "file": "src/components/apply/ApplyForm.tsx",
      "type": "client",
      "props": [
        { "name": "locale", "type": "Locale", "required": true },
        { "name": "t", "type": "Translator (apply namespace)", "required": true }
      ],
      "contractRef": "#/schemas/ApplyLeadRequest",
      "dataShape": {
        "eyebrow": "apply.eyebrow",
        "heading": "apply.heading",
        "description": "apply.description",
        "loanDetailsTitle": "apply.loanDetailsTitle",
        "amountLabel": "apply.amountLabel",
        "tenureLabel": "apply.tenureLabel",
        "purposeLabel": "apply.purposeLabel",
        "purposes": "apply.purposes",
        "aboutYouTitle": "apply.aboutYouTitle",
        "fullNameLabel": "apply.fullNameLabel",
        "mobileLabel": "apply.mobileLabel",
        "mobilePlaceholder": "apply.mobilePlaceholder",
        "emailLabel": "apply.emailLabel",
        "pinCodeLabel": "apply.pinCodeLabel",
        "pinCodePlaceholder": "apply.pinCodePlaceholder",
        "emiLabel": "apply.emiLabel",
        "emiNoteTemplate": "apply.emiNoteTemplate",
        "consentDataPrefix": "apply.consentDataPrefix",
        "consentAnd": "apply.consentAnd",
        "consentPolicy": "apply.consentPolicy",
        "privacyPolicy": "apply.privacyPolicy",
        "consentLender": "apply.consentLender",
        "submit": "apply.submit",
        "submitting": "apply.submitting",
        "successHeading": "apply.successHeading",
        "successBody": "apply.successBody",
        "successCta": "apply.successCta",
        "errorHeading": "apply.errorHeading",
        "errorBody": "apply.errorBody",
        "fieldRequired": "apply.fieldRequired",
        "validation": "apply.validation"
      },
      "fields": [
        {
          "name": "amount",
          "type": "number",
          "min": 500000,
          "max": 10000000,
          "control": "slider or stepper"
        },
        { "name": "tenure", "type": "number", "min": 3, "max": 12, "control": "slider or stepper" },
        { "name": "purpose", "type": "LoanPurpose", "control": "select" },
        {
          "name": "fullName",
          "type": "string",
          "minLength": 2,
          "maxLength": 150,
          "pattern": "^[A-Za-z\\s'.-]+$"
        },
        {
          "name": "mobile",
          "type": "string",
          "pattern": "^[6-9]\\d{9}$",
          "placeholder": "apply.mobilePlaceholder"
        },
        { "name": "email", "type": "string", "format": "email", "maxLength": 255 },
        {
          "name": "pinCode",
          "type": "string",
          "pattern": "^[1-9]\\d{5}$",
          "placeholder": "apply.pinCodePlaceholder"
        },
        { "name": "consentData", "type": "boolean", "requiredValue": true },
        { "name": "consentLender", "type": "boolean", "requiredValue": true }
      ],
      "validationMessages": {
        "mobileInvalid": "apply.validation.mobileInvalid",
        "emailInvalid": "apply.validation.emailInvalid",
        "pinCodeInvalid": "apply.validation.pinCodeInvalid",
        "nameInvalid": "apply.validation.nameInvalid",
        "consentRequired": "apply.validation.consentRequired"
      },
      "rules": [
        "Client must generate an Idempotency-Key (UUID or fallback timestamp token) and send it in the request header.",
        "Inline validation must run on blur/submit with localized error strings.",
        "Success and error states must use localized headings and bodies.",
        "EMI note may interpolate values using apply.emiNoteTemplate."
      ]
    },
    {
      "name": "TeamPage",
      "file": "app/[locale]/team/page.tsx",
      "type": "server",
      "props": [{ "name": "locale", "type": "Locale", "required": true }],
      "dataSource": {
        "static": "src/lib/data/team.json",
        "translatorNamespace": "team"
      },
      "sections": [
        { "order": 1, "component": "TeamHero", "keys": ["team.hero"] },
        { "order": 2, "component": "TeamMembers", "keys": ["team.members"], "dataKey": "members" },
        { "order": 3, "component": "Advisors", "keys": ["team.advisors"], "dataKey": "advisors" },
        { "order": 4, "component": "JoinCta", "keys": ["team.join"] }
      ]
    },
    {
      "name": "TeamCard",
      "file": "src/components/team/TeamCard.tsx",
      "type": "server",
      "props": [
        { "name": "member", "type": "TeamMember", "required": true },
        { "name": "t", "type": "Translator", "required": false }
      ],
      "contractRef": "team.json member schema",
      "itemFields": {
        "id": "stable id",
        "name": "full name (static)",
        "roleKey": "localized role text; must use 'Borrower Onboarding' instead of 'Marketplace Onboarding'",
        "bioKey": "localized bio text",
        "imageAsset": "public asset path",
        "linkedIn": "optional LinkedIn URL"
      },
      "notes": [
        "For Divyesh Reddy, update roleKey from 'Marketplace Onboarding' to 'Borrower Onboarding' per UX requirement."
      ]
    },
    {
      "name": "AdvisorCard",
      "file": "src/components/team/AdvisorCard.tsx",
      "type": "server",
      "props": [{ "name": "advisor", "type": "Advisor", "required": true }],
      "contractRef": "team.json advisor schema",
      "itemFields": {
        "id": "stable id",
        "name": "full name (static)",
        "domainKey": "localized domain text",
        "contributionKey": "localized contribution text",
        "imageAsset": "public asset path",
        "linkedIn": "optional LinkedIn URL"
      }
    }
  ],
  "alignmentNotes": [
    "All homepage list data (loanProducts, whyReasons, recognitionItems, customerStories) must flow through translator keys or static registries copied from contract definitions.",
    "Existing message JSON uses some differing key names (home.whyNavdhan vs contract home.whyNavDhan, home.stories vs home.customerStories, home.emi vs home.emiCalculator). Frontend implementation should migrate to contract paths.",
    "Footer badges array must be rendered via t() array join with ' · '.",
    "Apply form fields must match ApplyLeadRequest validation and use apply.* message keys."
  ]
}
